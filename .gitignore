# Local install / runtime artifacts
.claude/settings.local.json
.claude/audit.log
.claude/somi-state/
.somi-state/
# Defensive: if a host doesn't expand ${CLAUDE_PROJECT_DIR} in settings.json's env block,
# the audit hook could create a literal-named directory here before the path guard in
# hooks/lib/common.sh resolves it. Never commit that runtime artifact.
${CLAUDE_PROJECT_DIR}/

