      "payload": { "tool_name": "Bash", "tool_input": { "command": "echo FOO=1 >> /app/.env" } } },
    { "name": "tee-dotenv", "expect": "deny",
      "expect_reason": "tee .env",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "cat template | tee .env" } } },
    { "name": "sed-inplace-dotenv", "expect": "deny",
      "expect_reason": "sed -i s/OLD/NEW/ .env",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "sed -i 's/OLD/NEW/' .env" } } },
    { "name": "cp-onto-dotenv", "expect": "deny",
      "expect_reason": "cp .env.backup .env",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "cp .env.backup .env" } } },
    { "name": "redirect-to-pem", "expect": "deny",
      "expect_reason": "> server.pem",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "openssl genrsa 2048 > server.pem" } } },

    { "name": "rm-rf-relative-build", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "rm -rf ./build" } } },
    { "name": "rm-rf-node-modules", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "rm -rf node_modules" } } },
    { "name": "plain-push-feature-branch", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git push origin feature-x" } } },
    { "name": "force-with-lease-explicit-feature", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git push --force-with-lease origin feature-x" } } },
    { "name": "redirect-to-env-example", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "echo \"API_KEY=\" > .env.example" } } },
    { "name": "redirect-to-plain-file", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "echo hi > notes.txt" } } },
    { "name": "plain-commit", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git commit -m \"feat: add limiter\"" } } },
    { "name": "select-query", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "psql -c \"SELECT * FROM users;\"" } } },
    { "name": "delete-with-where-no-semicolon", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "psql -c \"DELETE FROM orders WHERE id = 5\"" } } },
    { "name": "npm-test", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "npm test" } } },
    { "name": "fork-bomb", "expect": "deny",
      "expect_reason": ":(){ :|:& };:",
      "payload": { "tool_name": "Bash", "tool_input": { "command": ":(){ :|:& };:" } } },
    { "name": "device-write-sda", "expect": "deny",
      "expect_reason": "> /dev/sda",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "echo x > /dev/sda" } } },
    { "name": "dd-to-device-cr-embedded", "expect": "deny",
      "expect_reason": "of=/dev/sda",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "dd if=a\rb of=/dev/sda" } } },
    { "name": "mkfs-dot-variant", "expect": "deny",
      "expect_reason": "mkfs.",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "mkfs.ext4 /dev/sdb1" } } },
    { "name": "chmod-777-root", "expect": "deny",
      "expect_reason": "chmod -R 777 /",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "chmod -R 777 /" } } },
    { "name": "chown-root", "expect": "deny",
      "expect_reason": "chown -R user:group /",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "chown -R user:group /" } } },
    { "name": "branch-delete-main", "expect": "deny",
      "expect_reason": "git branch -D main",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git branch -D main" } } },
    { "name": "push-no-verify", "expect": "deny",
      "expect_reason": "--no-verify",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git push origin main --no-verify" } } },
    { "name": "drop-database", "expect": "deny",
      "expect_reason": "DROP DATABASE",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "psql -c \"DROP DATABASE prod\"" } } },
    { "name": "drop-schema-production", "expect": "deny",
      "expect_reason": "DROP SCHEMA production",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "psql -c \"DROP SCHEMA production\"" } } },
    { "name": "secret-write-mv-idrsa", "expect": "deny",
      "expect_reason": "mv id_rsa.new id_rsa",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "mv id_rsa.new id_rsa" } } },
    { "name": "secret-write-exception-then-real-write", "expect": "deny",
      "expect_reason": "cp backup.env .env",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "sed -i s/a/b/ .env.example && cp backup.env .env" } } },
    { "name": "bare-force-push-allow-explicit-branch", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git push -f origin feature-x" } } },
    { "name": "bare-force-push-allow-lease-explicit-branch", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git push --force-with-lease origin my-branch" } } },
    { "name": "git-clean-fdx-no-trailing-boundary", "expect": "allow",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git clean -fdx" } } },
    { "name": "f39-lf-git-commit-no-verify-spans-newline", "expect": "deny",
      "expect_reason": "--no-verify",
      "_note": "F-39 non-vacuity: bash [[ =~ ]] . matches newline; the deny reason contains --no-verify only if [^] spanned the multi-line commit body. A [^\\n] regression ALLOWS this (empty reason) and the case fails.",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git commit -m \"fix\n\nlonger body\" --no-verify" } } },
    { "name": "f39-lf-git-push-no-verify-spans-newline", "expect": "deny",
      "expect_reason": "--no-verify",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "git push origin main\ndeploy --no-verify" } } },
    { "name": "f39-lf-dd-to-device-spans-newline", "expect": "deny",
      "expect_reason": "of=/dev/sda",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "dd if=a\nb of=/dev/sda" } } },
    { "name": "f39-lf-chown-r-root-spans-newline", "expect": "deny",
      "expect_reason": "chown -R a",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "chown -R a\nb /" } } },
    { "name": "f40-nbsp-secret-cp-service-account", "expect": "deny",
      "expect_reason": "creds.json",
      "_note": "F-40 non-vacuity: bash [^[:space:]] matches NBSP; creds.json in the reason proves the negated class matched THROUGH the NBSP to the .json anchor. A [^\\s] regression ALLOWS this and the case fails.",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "cp leaked service-account creds.json" } } },
    { "name": "f40-nbsp-secret-redirect-env-prefix", "expect": "deny",
      "expect_reason": ".env",
      "payload": { "tool_name": "Bash", "tool_input": { "command": "echo SECRET > dir /.env" } } }
  ]
}
