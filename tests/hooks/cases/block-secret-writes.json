{
  "script": "pre-tool/block-secret-writes.mjs",
  "cases": [
    { "name": "write-dotenv", "expect": "deny",
      "payload": { "tool_name": "Write", "tool_input": { "file_path": "/repo/.env" } } },
    { "name": "edit-id-rsa", "expect": "deny",
      "payload": { "tool_name": "Edit", "tool_input": { "file_path": "/home/u/.ssh/id_rsa" } } },
    { "name": "write-service-account-key", "expect": "deny",
      "payload": { "tool_name": "Write", "tool_input": { "file_path": "/repo/infra/service-account-prod.json" } } },
    { "name": "write-secrets-yaml", "expect": "deny",
      "payload": { "tool_name": "Write", "tool_input": { "file_path": "/repo/config/secrets.yaml" } } },
    { "name": "write-pem", "expect": "deny",
      "payload": { "tool_name": "Write", "tool_input": { "file_path": "/repo/certs/server.pem" } } },

    { "name": "write-env-example", "expect": "allow",
      "payload": { "tool_name": "Write", "tool_input": { "file_path": "/repo/.env.example" } } },
    { "name": "write-source-file", "expect": "allow",
      "payload": { "tool_name": "Write", "tool_input": { "file_path": "/repo/src/main.ts" } } },
    { "name": "write-environment-ts-not-dotenv", "expect": "allow",
      "payload": { "tool_name": "Write", "tool_input": { "file_path": "/repo/src/environment.ts" } } }
  ]
}
