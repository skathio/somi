{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Reference settings for somi when used VENDORED (copied into a project's .claude/ tree) instead of installed as a plugin. For the plugin install path, hooks/hooks.json is the source of truth and Claude Code merges it automatically using ${CLAUDE_PLUGIN_ROOT}. Vendored installs may copy this file (or merge its hooks block) into their own .claude/settings.json and adjust SOMI_VENDOR_ROOT to point at the hook scripts.",
  "env": {
    "SOMI_VENDOR_ROOT": "${CLAUDE_PROJECT_DIR}/.claude/plugins/somi",
    "SOMI_AUDIT_LOG": "${CLAUDE_PROJECT_DIR}/.claude/audit.log"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(rg:*)",
      "Bash(jq:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./*.pem)",
      "Read(./*.key)",
      "Read(./id_rsa*)",
      "Read(./id_ed25519*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${SOMI_VENDOR_ROOT}/hooks/session-start/detect-repo-instructions.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${SOMI_VENDOR_ROOT}/hooks/pre-tool/block-dangerous-bash.mjs"
          },
          {
            "type": "command",
            "command": "node ${SOMI_VENDOR_ROOT}/hooks/pre-tool/gate-dep-install.mjs"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${SOMI_VENDOR_ROOT}/hooks/pre-tool/block-secret-writes.mjs"
          },
          {
            "type": "command",
            "command": "node ${SOMI_VENDOR_ROOT}/hooks/pre-tool/guard-protected-paths.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${SOMI_VENDOR_ROOT}/hooks/post-tool/lint-changed-files.mjs"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${SOMI_VENDOR_ROOT}/hooks/post-tool/audit-log.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${SOMI_VENDOR_ROOT}/hooks/user-prompt-submit/inject-workflow-context.mjs"
          }
        ]
      }
    ]
  }
}
